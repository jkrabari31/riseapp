generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  role           String          @default("INTERN") // SUPER_ADMIN, ADMISSION_OFFICER, TRAINER, INTERN, CEO
  name           String
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  StudentParent  Student[]       @relation("ParentToStudent")
  Announcements  Announcement[]  @relation("AuthorToAnnouncement")
  TeacherProfile TeacherProfile?
  notifications  Notification[]  @relation("UserToNotification")

  schedulesCreated TrainingSchedule[] @relation("ScheduleCreator")
  schedulesUpdated TrainingSchedule[] @relation("ScheduleUpdater")

  @@index([role, isActive])
}

model Subject {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teachers    TeacherProfile[] @relation("TeacherToSubject")
  timetables  Timetable[]      @relation("SubjectToTimetable")
  assignments Assignment[]     @relation("SubjectToAssignment")
  assessments Assessment[]     @relation("SubjectToAssessment")
}

model TeacherProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName  String
  middleName String?
  lastName   String
  mobileNo   String?

  assignedClasses    String?  @db.Text // e.g. "1st,2nd,3rd"
  classTeacherFor    String?  @db.Text // e.g. "1st"
  canEditTimetable   Boolean  @default(false) // Admin grants this to specific teachers

  subjects    Subject[]    @relation("TeacherToSubject")
  timetables  Timetable[]  @relation("TeacherToTimetable")
  assignments Assignment[] @relation("TeacherToAssignment")
  assessments Assessment[] @relation("TeacherToAssessment")

  scheduledSessions ScheduleTrainer[]
  readingMaterials  ReadingMaterial[] @relation("TrainerToReadingMaterial")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firstName, lastName])
}

model Student {
  id              String   @id @default(uuid())
  admissionNumber String   @unique
  firstName       String
  middleName      String?
  lastName        String
  
  // Legacy compatibility / Derived
  name            String?
  
  dateOfBirth     DateTime?
  gender          String?
  classLevel      String?
  section         String?
  rollNumber      String?
  address         String?
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE, ALUMNI

  // Internship Fields
  education       String?
  collegeName     String?
  universityName  String?
  mobileNo        String?
  email           String?
  parentsMobileNo String?
  interestedCourse String?
  fatherOccupation String?
  cgpa            String?
  passingYear     String?
  city            String?
  source          String? // How to know about us

  fatherName    String?
  motherName    String?
  contactNumber String?
  parentEmail   String?

  parentId String?
  parent   User?   @relation("ParentToStudent", fields: [parentId], references: [id])

  specializationId String?
  specialization   Specialization? @relation(fields: [specializationId], references: [id])
  batchId          String?
  batch            Batch?          @relation(fields: [batchId], references: [id])
  
  academicYearId   String?
  academicYear     AcademicYear?   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  
  photoUrl         String?         @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances           Attendance[]
  fees                  Fee[]
  assessmentSubmissions AssessmentSubmission[]
  emiPlan               EmiPlan?
  readingProgress       ReadingProgress[]

  @@index([classLevel, section])
  @@index([status])
  @@index([name])
  @@index([batchId])
  @@index([parentId])
  @@index([email])
  @@index([specializationId])
}

model Attendance {
  id      String   @id @default(uuid())
  date    DateTime
  status  String // PRESENT, ABSENT, LATE, HALF_DAY
  remarks String?

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  batchId   String?
  batch     Batch?   @relation(fields: [batchId], references: [id])

  classLevel String? // Legacy compatibility
  section    String? // Legacy compatibility

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([date, batchId])
  @@index([studentId])
}

model FeeStructure {
  id               String @id @default(uuid())
  specializationId String @unique
  tuitionFee       Float
  otherCharges     Float
  totalAmount      Float

  specialization   Specialization @relation(fields: [specializationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Fee {
  id            String   @id @default(uuid())
  amountPaid    Float
  dueAmount     Float
  paymentDate   DateTime
  paymentMode   String // CASH, UPI, BANK, RAZORPAY
  receiptNumber String   @unique

  // Razorpay fields
  razorpayOrderId   String?
  razorpayPaymentId String?

  // EMI tracking
  emiInstallmentNo  Int?

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paymentDate])
  @@index([studentId])
}

model AdmissionRequest {
  id              String @id @default(uuid())
  referenceNumber String @unique // e.g. APP-2024-001
  status          String @default("PENDING") // PENDING, APPROVED, REJECTED

  // Intern Details
  firstName       String
  middleName      String?
  lastName        String
  education       String?
  collegeName     String?
  universityName  String?
  mobileNo        String?
  email           String 
  parentsMobileNo String?
  interestedCourse String?
  interestedBatch  String?
  fatherOccupation String?
  cgpa            String?
  passingYear     String?
  address         String
  city            String?
  source          String? // How to know about us

  // System
  dateOfBirth     DateTime?
  gender          String?
  classAppliedFor String?
  
  fatherName      String?
  motherName      String?
  contactNumber   String?
  photoUrl        String?  @db.Text

  // System
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Announcement {
  id         String @id @default(uuid())
  title      String
  content    String
  targetRole String @default("ALL") // ALL, SUPER_ADMIN, ADMISSION_OFFICER, TRAINER, INTERN
  priority   String @default("NORMAL") // URGENT, HIGH, NORMAL

  authorId String
  author   User   @relation("AuthorToAnnouncement", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id       String  @id @default(uuid())
  title    String
  message  String
  type     String  @default("INFO") // INFO, ALERT, SUCCESS
  priority String  @default("NORMAL") // URGENT, HIGH, NORMAL
  isRead   Boolean @default(false)

  userId String
  user   User   @relation("UserToNotification", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model NotificationConfig {
  id              String   @id @default(uuid())
  assignmentInApp Boolean  @default(true)
  assignmentEmail Boolean  @default(true)
  assessmentInApp Boolean  @default(true)
  assessmentEmail Boolean  @default(true)
  feeInApp        Boolean  @default(true)
  feeEmail        Boolean  @default(true)
  admissionInApp  Boolean  @default(true)
  admissionEmail  Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}


model SystemSettings {
  id               String @id @default(uuid())
  instituteName    String @default("Rishabh Software")
  registrationCode String @default("RISE-0000-IND")
  
  currentYearId    String?
  currentYear      AcademicYear? @relation("CurrentYearToSettings", fields: [currentYearId], references: [id])
  
  academicYear     String @default("2024 - 2025") // Legacy
  contactEmail     String @default("admin@rise.in")
  address          String @default("123 Innovation Lane, Tech City")

  updatedAt DateTime @updatedAt
}

model AcademicYear {
  id        String   @id @default(uuid())
  name      String   @unique // e.g. "2024-2025"
  startDate DateTime?
  endDate   DateTime?
  isCurrent Boolean  @default(false)
  
  batches     Batch[]
  students    Student[]
  fees        Fee[]
  assessments Assessment[]
  
  settingsCurrent SystemSettings[] @relation("CurrentYearToSettings")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Timetable {
  id           String @id @default(uuid())
  classLevel   String // e.g. "1st", "10th"
  section      String // e.g. "A", "B", "Sci"
  dayOfWeek    String // e.g. "MONDAY", "TUESDAY"
  periodNumber Int    // e.g. 1, 2, 3
  startTime    String // e.g. "08:00 AM"
  endTime      String // e.g. "08:45 AM"
  weekStart    String // "YYYY-MM-DD" — the Monday of this calendar week, e.g. "2025-03-10"

  subjectId    String
  subject      Subject @relation("SubjectToTimetable", fields: [subjectId], references: [id])

  teacherId    String
  teacher      TeacherProfile @relation("TeacherToTimetable", fields: [teacherId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([classLevel, section, dayOfWeek, periodNumber, weekStart])
  @@unique([teacherId, dayOfWeek, periodNumber, weekStart])
  @@index([weekStart])
}

model Assignment {
  id            String   @id @default(uuid())
  title         String
  description   String?
  questionsJSON String   @db.Text // Storing an array of questions as a JSON string
  dueDate       DateTime
  
  batchId          String?
  batch            Batch?          @relation(fields: [batchId], references: [id])
  specializationId String?
  specialization   Specialization? @relation(fields: [specializationId], references: [id])

  classLevel    String? // Legacy
  section       String? // Legacy

  subjectId     String
  subject       Subject @relation("SubjectToAssignment", fields: [subjectId], references: [id])

  teacherId     String
  teacher       TeacherProfile @relation("TeacherToAssignment", fields: [teacherId], references: [id])
  
  isReleased    Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Assessment {
  id            String   @id @default(uuid())
  title         String
  description   String?
  questionsJSON String   @db.Text // JSON array: [{question, options:[str,str,str,str], correctIndex:number}]
  dueDate       DateTime
  timeLimit     Int      @default(30) // minutes
  
  batchId          String?
  batch            Batch?          @relation(fields: [batchId], references: [id])
  specializationId String?
  specialization   Specialization? @relation(fields: [specializationId], references: [id])

  classLevel    String? // Legacy
  section       String? // Legacy

  subjectId     String
  subject       Subject @relation("SubjectToAssessment", fields: [subjectId], references: [id])

  teacherId     String
  teacher       TeacherProfile @relation("TeacherToAssessment", fields: [teacherId], references: [id])

  submissions   AssessmentSubmission[]
  
  isReleased    Boolean  @default(false)
  
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([classLevel, section])
  @@index([batchId])
  @@index([specializationId])
}

model AssessmentSubmission {
  id             String   @id @default(uuid())
  answersJSON    String   @db.Text // JSON array of chosen option indices e.g. [0,2,1,3]
  score          Int
  totalQuestions Int
  submittedAt    DateTime @default(now())

  assessmentId   String
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  studentId      String
  student        Student @relation(fields: [studentId], references: [id])

  @@unique([assessmentId, studentId])
  @@index([studentId])
  @@index([assessmentId])
}

model Batch {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., "Batch 2024-A"
  
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  specializations BatchSpecialization[]
  schedules       TrainingSchedule[]
  students        Student[]
  attendances     Attendance[]
  assessments     Assessment[]
  assignments     Assignment[]
}

model Specialization {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "Java+React", "Data Science"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batchSpecializations BatchSpecialization[]
  scheduleMappings     ScheduleSpecialization[]
  students             Student[]
  assessments          Assessment[]
  assignments          Assignment[]
  feeStructure         FeeStructure?
  readingMaterials     ReadingMaterial[]
}

model BatchSpecialization {
  id               String @id @default(uuid())
  batchId          String
  specializationId String
  studentCount     Int    @default(0)

  batch            Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  specialization   Specialization @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@unique([batchId, specializationId])
}

model Room {
  id        String   @id @default(uuid())
  name      String   @unique // Nalanda, Vallabhi, Somapura, Shantiniketan
  capacity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedules TrainingSchedule[]
}

model TimeSlot {
  id            String   @id @default(uuid())
  startTime     String   // e.g., "09:00 AM"
  endTime       String   // e.g., "10:00 AM"
  durationHours Float    // e.g., 1.0, 1.25
  slotOrder     Int      @unique // 1 to 8

  schedules TrainingSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainingSchedule {
  id          String   @id @default(uuid())
  date        DateTime
  monthNo     Int      // 1 to 6
  type        String   // Technical, Communication, Softskills
  focus       String
  topic       String
  mode        String   // ILT, Practice, Measurement
  status      String   @default("YetToStart") // YetToStart, Completed
  isCommon    Boolean  @default(false)
  externalTrainer String?  // For unregistered guest trainers

  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id])

  timeSlotId  String
  timeSlot    TimeSlot @relation(fields: [timeSlotId], references: [id])

  roomId      String
  room        Room     @relation(fields: [roomId], references: [id])

  createdById String
  createdBy   User     @relation("ScheduleCreator", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?    @relation("ScheduleUpdater", fields: [updatedById], references: [id])

  trainers        ScheduleTrainer[]
  specializations ScheduleSpecialization[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, timeSlotId, roomId]) // Prevent room double booking
  @@index([date, batchId])
  @@index([status])
}

model ScheduleSpecialization {
  id               String @id @default(uuid())
  scheduleId       String
  specializationId String

  schedule       TrainingSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  specialization Specialization   @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, specializationId])
  @@index([specializationId])
}

model ScheduleTrainer {
  id         String @id @default(uuid())
  scheduleId String
  trainerId  String // Link to TeacherProfile.id

  schedule TrainingSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  trainer  TeacherProfile   @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, trainerId])
  @@index([trainerId])
}

model EmiPlan {
  id                String   @id @default(uuid())
  totalInstallments Int      // 1 to 6
  installmentAmount Float    // per installment amount
  totalAmount       Float    // total fee amount
  paidInstallments  Int      @default(0)
  status            String   @default("ACTIVE") // ACTIVE, COMPLETED

  studentId         String   @unique
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ReadingMaterial {
  id               String   @id @default(uuid())
  title            String
  content          String   @db.Text
  
  // Link to the trainer who created it
  authorId         String
  author           TeacherProfile @relation("TrainerToReadingMaterial", fields: [authorId], references: [id])
  
  // Link to the specialization it's assigned to
  specializationId String
  specialization   Specialization @relation(fields: [specializationId], references: [id])
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  progressTracking ReadingProgress[]
}

model ReadingProgress {
  id                 String   @id @default(uuid())
  progressPercentage Int      @default(0) // 0 to 100
  status             String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  lastReadAt         DateTime?
  
  materialId         String
  material           ReadingMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  
  studentId          String
  student            Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([materialId, studentId])
}

model Lead {
  id               String   @id @default(uuid())
  firstName        String
  lastName         String?
  mobileNo         String
  email            String?
  education        String?
  city             String?
  fatherOccupation String?
  collegeName      String?
  cgpa             String?
  interestedCourse String?
  interestedBatch  String?
  
  status           String   @default("NEW") // NEW, INTERESTED, MAYBE, NOT_INTERESTED, ADMITTED
  followUpDate     DateTime?
  
  remarks          LeadRemark[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([followUpDate])
}

model LeadRemark {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  remark    String   @db.Text
  createdAt DateTime @default(now())
}
